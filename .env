PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/connect

JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production_min_32chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Connect <noreply@connect.app>

FRONTEND_URL=http://localhost:5173

UPLOAD_PATH=uploads/profiles
MAX_FILE_SIZE=5242880

OTP_EXPIRES_MINUTES=10
SWIPE_DAILY_LIMIT=50
SUPERLIKE_DAILY_LIMIT=5
REPORT_SHADOW_BAN_THRESHOLD=3
REPORT_BAN_THRESHOLD=5

ADMIN_ROLE_SECRET=change_this_to_a_strong_secret_for_admin_creation
